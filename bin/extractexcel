#!/usr/bin/python3
#
# extractexcel
#
# Extract raw data from excel, disregarding all formatting
#

import sys, os.path
import libs.excel.xlsx, libs.excel.legacy

class ExcelExtractor:
    def warn(self, *arguments):
        print(*arguments, file=sys.stderr)

    def error(self, *arguments):
        self.warn(*arguments)
        sys.exit(2)

    def processCommandLine(self, argv):
        self.processFiles(argv[1:])

    def processFiles(self, files):
        for file in files:
            self.processFile(file)

    def processFile(self, file):
        self.warn('Extract', file)
        root, extension = os.path.splitext(file)
        if extension == '':
            self.error('Missing file extension.')
        if extension not in ['.xlsx', '.xls', '.xml']:
            self.error(f'Unexpected file extension {extension}.')
        if self.isZipFile(file):
            libs.excel.xlsx.Extractor(file).process()
        elif self.isXMLFile(file):
            libs.excel.legacy.Extractor(file).process()
        else:
            self.error('Unexpected file format.')

    def isZipFile(self, file):
        with open(file, 'rb') as stream:
            contents = stream.read(10)
        return contents.startswith(b'PK')

    def isXMLFile(self, file):
        with open(file, 'rb') as stream:
            contents = stream.read(10)
        return contents.startswith(b'<')

if __name__ == '__main__':
    ExcelExtractor().processCommandLine(sys.argv)

